# Copy to .env and fill in. docker-compose reads it automatically.
# .env is gitignored — keep real secrets here, never in tracked files.

# --- Strava MCP (remote HTTP/SSE) ---
STRAVA_MCP_URL=https://your-strava-mcp.example/mcp
STRAVA_MCP_TOKEN=          # or put the token in ./data/strava_token instead
STRAVA_MCP_TRANSPORT=http  # http or sse

# --- Claude subscription auth ---
# Leave blank and run `claude setup-token` inside the container (see README),
# OR paste the token from `claude setup-token` here.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Networking ---
# LAN-only binding. Default "8080" publishes on all host interfaces (fine on a
# trusted LAN behind a firewall). To pin to one interface use the full form,
# e.g.  COACH_BIND=192.168.1.10:8080:8080
COACH_BIND=8080

# --- Behavior ---
COACH_SYNC_INTERVAL=3600   # seconds between Strava syncs (default hourly)
COACH_MODEL=               # blank = SDK default; e.g. "sonnet"
